# ---------------------------------------------------------------------------
# Clerk (auth) — required
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ---------------------------------------------------------------------------
# Supabase / Postgres — required for /admin and ingest
# Use the Supabase pooler URI (postgres.js auto-disables prepared statements).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# n8n integration — required
# ---------------------------------------------------------------------------
# Chat RAG webhook (called by /api/chat).
N8N_WEBHOOK_URL=https://your-instance.n8n.cloud/webhook/company-chat

# Manual ingest dispatcher (called by /api/orgs/[orgId]/ingest).
INGEST_WEBHOOK_URL=https://your-instance.n8n.cloud/webhook/company-ingest

# Invite email workflow (optional — leave blank to skip emails).
# INVITE_WEBHOOK_URL=https://your-instance.n8n.cloud/webhook/company-invite

# Shared secret sent as X-Webhook-Secret header on every n8n call (and validated
# on /api/internal/ingest-jobs/[jobId] callbacks). Rotate via docs/WEBHOOK_SECURITY_ROTATION.md.
WEBHOOK_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Branding (public marketing site)
# ---------------------------------------------------------------------------
COMPANY_NAME=NovaCompany
NEXT_PUBLIC_BRAND_NAME=Your Company
NEXT_PUBLIC_BRAND_TAGLINE=Customer support assistant

# ---------------------------------------------------------------------------
# First-user bootstrap (Sprint 1)
# When a brand-new platform user signs in and no org exists yet, create one
# with this slug/name and attach them as org_owner.
# ---------------------------------------------------------------------------
# BOOTSTRAP_ORG_SLUG=demo-company
# BOOTSTRAP_ORG_NAME=Demo organization

# Legacy mode: bootstrap EVERY new user into the bootstrap org. Dev/demo only.
# ALLOW_AUTO_BOOTSTRAP_ALL_USERS=false

# ---------------------------------------------------------------------------
# Sentry (optional — leave unset to disable error reporting)
# Create a project at https://sentry.io → copy DSN.
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ---------------------------------------------------------------------------
# KB status card model labels (optional — must match n8n OpenRouter models)
# ---------------------------------------------------------------------------
# CHAT_MODEL=openai/gpt-4.1-mini
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ---------------------------------------------------------------------------
# Rate limiting (optional — defaults shown)
# Public chat throttle: requests per IP per window.
# ---------------------------------------------------------------------------
# CHAT_RATE_LIMIT_PER_MINUTE=30
