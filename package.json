{
  "name": "company-chat-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs apply",
    "db:migrate:status": "node --env-file=.env.local scripts/migrate.mjs status",
    "db:migrate:mark": "node --env-file=.env.local scripts/migrate.mjs mark",
    "db:migrate:rls": "node --env-file=.env.local scripts/migrate.mjs apply --include-optional",
    "db:backfill-docs-org": "node --env-file=.env.local scripts/backfill-documents-org.mjs",
    "verify:tenant-isolation": "node --env-file=.env.local scripts/verify-tenant-isolation.mjs",
    "ingest:kb-url": "node --env-file=.env.local scripts/ingest-kb-url.mjs",
    "rotate:secrets": "node scripts/rotate-secrets.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.1",
    "@sentry/nextjs": "^10.53.1",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
